      private function initRondomPro() : Object
      {
         var count:int = 0;
         var element:String = null;
         var index:int = 0;
         var result:Object = {
            "tu":false,
            "huo":false,
            "mu":false,
            "shui":false,
            "jin":false
         };
         var elements:Array = ["jin","mu","shui","huo","tu"];
         var rand:Number = Math.random();
         count = 5;
         var selected:Array = [];
         var available:Array = elements.slice();
         while(selected.length < count)
         {
            index = Math.floor(Math.random() * available.length);
            selected.push(available[index]);
            available.splice(index,1);
         }
         for each(element in selected)
         {
            result[element] = true;
         }
         return result;
      }
      
