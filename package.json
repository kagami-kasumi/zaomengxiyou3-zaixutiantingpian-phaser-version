{
  "name": "zaixu-tianding-modern",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test:systems": "node tools/run-system-tests.mjs",
    "check:structure": "node tools/check-structure.mjs",
    "check:code": "npm run test:systems && npm run build",
    "check:workflow": "node tools/validate-workflow.mjs",
    "check:all": "npm run check:workflow && npm run check:structure && npm run check:code"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
