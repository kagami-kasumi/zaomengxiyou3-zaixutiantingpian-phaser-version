{
  "name": "zaixu-tianding-modern",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:single": "vite --host 127.0.0.1 --open /",
    "dev:two": "vite --host 127.0.0.1 --open /?players=2",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test:systems": "node tools/run-system-tests.mjs",
    "test:stage11": "node tools/run-system-tests.mjs stage11-resource-tests",
    "test:stage11-flow": "node tools/run-system-tests.mjs stage11-flow-tests",
    "test:stage12": "node tools/run-system-tests.mjs stage12-resource-tests",
    "test:stage12-flow": "node tools/run-system-tests.mjs stage12-flow-tests",
    "test:stage12-traversal": "node tools/run-system-tests.mjs stage12-traversal-tests",
    "test:stage12-fb": "node tools/run-system-tests.mjs stage12-fb-enter-tests",
    "test:stage13": "node tools/run-system-tests.mjs stage13-resource-tests",
    "test:stage13-flow": "node tools/run-system-tests.mjs stage13-flow-tests",
    "test:stage13-traversal": "node tools/run-system-tests.mjs stage13-traversal-tests",
    "test:stage1-combat": "node tools/run-system-tests.mjs stage1-combat-tests",
    "test:stage1-hud": "node tools/run-system-tests.mjs stage1-hud-tests",
    "test:save-slots": "node tools/run-system-tests.mjs save-slot-tests",
    "test:heaven-map": "node tools/run-system-tests.mjs heaven-map-tests",
    "test:feature-ui-host": "node tools/run-system-tests.mjs feature-ui-host-tests",
    "test:feature-save-v4": "node tools/run-system-tests.mjs feature-save-v4-tests",
    "test:formal-inventory": "node tools/run-system-tests.mjs formal-inventory-tests",
    "test:monster-runtime": "node tools/run-system-tests.mjs monster-runtime-tests",
    "check:structure": "node tools/check-structure.mjs",
    "check:code": "npm run test:systems && npm run build",
    "check:annotations": "node tools/validate-asset-annotations.mjs",
    "audit:crafting-coverage": "node tools/run-crafting-coverage-audit.mjs",
    "generate:crafting-item-catalog": "node tools/generate-crafting-item-catalog.mjs",
    "generate:crafting-icon-catalog": "node tools/generate-crafting-icon-catalog.mjs",
    "check:workflow": "node tools/validate-workflow.mjs && node tools/validate-asset-annotations.mjs",
    "check:all": "npm run check:workflow && npm run check:structure && npm run check:code"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
